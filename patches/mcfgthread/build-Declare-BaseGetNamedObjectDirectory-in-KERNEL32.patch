From 7301641e1f16e674f066541be25abd1f8e406ea4 Mon Sep 17 00:00:00 2001
From: LIU Hao <lh_mouse@126.com>
Date: Tue, 13 May 2025 21:12:43 +0800
Subject: [PATCH] build: Declare `BaseGetNamedObjectDirectory()` in
 KERNEL32.DEF

This function is available since Windows 7.

Even without the declaration, linking may seem to work because when targeting
Windows Meson has a pre-defined list of libraries. Since we are using
`-nostdlib` for DLLs, we override that option with an empty string.

This fixes https://github.com/lhmouse/mcfgthread/issues/284.

Signed-off-by: LIU Hao <lh_mouse@126.com>
---
 mcfgthread/kernel32.def      | 1 +
 mcfgthread/kernel32.i386.def | 1 +
 meson.build                  | 2 ++
 3 files changed, 4 insertions(+)

diff --git a/mcfgthread/kernel32.def b/mcfgthread/kernel32.def
index 8f44953..8e07c43 100644
--- a/mcfgthread/kernel32.def
+++ b/mcfgthread/kernel32.def
@@ -7,6 +7,7 @@
 
 LIBRARY "KERNEL32.DLL"
 EXPORTS
+  BaseGetNamedObjectDirectory
   CreateThread
   DecodePointer
   EncodePointer
diff --git a/mcfgthread/kernel32.i386.def b/mcfgthread/kernel32.i386.def
index 4d0fc98..4c5b302 100644
--- a/mcfgthread/kernel32.i386.def
+++ b/mcfgthread/kernel32.i386.def
@@ -7,6 +7,7 @@
 
 LIBRARY "KERNEL32.DLL"
 EXPORTS
+  BaseGetNamedObjectDirectory@4
   CreateThread@24
   DecodePointer@4
   EncodePointer@4
diff --git a/meson.build b/meson.build
index adc7d53..706a16a 100644
--- a/meson.build
+++ b/meson.build
@@ -214,6 +214,7 @@ endif
 lib_mcfgthread_minimal_dll = shared_library('mcfgthread-minimal',
       c_pch: 'mcfgthread/xprecompiled.h',
       c_args: [ '-fasynchronous-unwind-tables', '-ffreestanding', '-D__MCF_IN_DLL' ],
+      override_options: { 'c_winlibs': '' },
       link_args: lib_mcfgthread_dll_link_args,
       sources: [ mcfgthread_src_min, mcfgthread_version_o ],
       dependencies: [ dep_kernel32, dep_ntdll ],
@@ -225,6 +226,7 @@ lib_mcfgthread_minimal_dll = shared_library('mcfgthread-minimal',
 lib_mcfgthread_dll = shared_library('mcfgthread',
       c_pch: 'mcfgthread/xprecompiled.h',
       c_args: [ '-fasynchronous-unwind-tables', '-ffreestanding', '-D__MCF_IN_DLL' ],
+      override_options: { 'c_winlibs': '' },
       link_args: lib_mcfgthread_dll_link_args,
       objects: lib_mcfgthread_minimal_dll.extract_objects(mcfgthread_src_min),
       sources: [ mcfgthread_src_ex, mcfgthread_version_o ],
-- 
2.48.1.windows.1

